{
  "name": "infinity-price-addin",
  "version": "1.0.0",
  "description": "Excel Add-in — use =INFINITY.LIVEPRICE() to stream live commodity prices",
  "main": "src/functions/functions.ts",
  "scripts": {
    "build": "webpack --mode production",
    "build:dev": "webpack --mode development",
    "dev-server": "webpack serve --mode development",
    "start": "office-addin-debugging start add_in.xml",
    "start:desktop": "office-addin-debugging start add_in.xml desktop",
    "start:web": "office-addin-debugging start add_in.xml web",
    "stop": "office-addin-debugging stop add_in.xml",
    "validate": "office-addin-manifest validate add_in.xml",
    "lint": "eslint src/**/*.ts",
    "sideload": "office-addin-dev-certs install && webpack serve --mode development"
  },
  "devDependencies": {
    "@types/custom-functions-runtime": "^1.6.11",
    "@types/node": "^25.3.3",
    "@types/office-js": "^1.0.377",
    "@types/office-runtime": "^1.0.35",
    "clean-webpack-plugin": "^4.0.0",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.2",
    "dotenv-webpack": "^8.1.0",
    "html-webpack-plugin": "^5.6.0",
    "mini-css-extract-plugin": "^2.9.0",
    "office-addin-debugging": "^6.0.6",
    "office-addin-dev-certs": "^1.13.5",
    "office-addin-manifest": "^1.13.5",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.4.5",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.0.4"
  }
}
